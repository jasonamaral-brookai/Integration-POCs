{
  "info": {
    "name": "athena CCDA Inbound — GET Patient CCDA",
    "description": "Pillar: CCDA Inbound (Phase 1a)\nEndpoint: GET /v1/{practiceid}/patients/{patientid}/ccda\n\nTODO: Verify exact endpoint path against athena developer docs. The build plan cites /v1/{practiceid}/ccda/{patientid}/ccda; the more standard REST form is /v1/{practiceid}/patients/{patientid}/ccda.\n\nRequired Postman environment variables:\n  athena_client_id\n  athena_client_secret\n  athena_practice_id\n  athena_patient_id\n  athena_base_url",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Step 1 — Acquire OAuth2 Token",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const clientId = pm.environment.get('athena_client_id');",
              "const clientSecret = pm.environment.get('athena_client_secret');",
              "if (!clientId || !clientSecret) {",
              "    throw new Error('athena_client_id and athena_client_secret must be set');",
              "}",
              "const credentials = btoa(clientId + ':' + clientSecret);",
              "pm.environment.set('athena_basic_auth', 'Basic ' + credentials);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Token acquired', function () {",
              "    pm.response.to.have.status(200);",
              "    const json = pm.response.json();",
              "    pm.expect(json.access_token).to.be.a('string').and.not.empty;",
              "    pm.environment.set('athena_access_token', json.access_token);",
              "    console.log('Token expires in: ' + json.expires_in + 's');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "{{athena_basic_auth}}"},
          {"key": "Content-Type", "value": "application/x-www-form-urlencoded"}
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [{"key": "grant_type", "value": "client_credentials"}]
        },
        "url": {
          "raw": "{{athena_base_url}}/oauth2/v1/token",
          "host": ["{{athena_base_url}}"],
          "path": ["oauth2", "v1", "token"]
        }
      }
    },
    {
      "name": "Step 2 — GET Patient CCDA",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Ensure token is available",
              "const token = pm.environment.get('athena_access_token');",
              "if (!token) {",
              "    throw new Error('athena_access_token not set — run Step 1 first');",
              "}",
              "const patientId = pm.environment.get('athena_patient_id');",
              "if (!patientId) {",
              "    throw new Error('athena_patient_id must be set in the Postman environment');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('CCDA returned successfully', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is XML', function () {",
              "    const ct = pm.response.headers.get('Content-Type') || '';",
              "    pm.expect(ct).to.satisfy(v => v.includes('xml'), 'Content-Type should contain xml');",
              "});",
              "",
              "pm.test('Response contains ClinicalDocument root element', function () {",
              "    const body = pm.response.text();",
              "    pm.expect(body).to.include('ClinicalDocument');",
              "});",
              "",
              "// Log size for capacity planning",
              "const sizeKb = Math.round(pm.response.responseSize / 1024);",
              "console.log('CCDA document size: ' + sizeKb + ' KB');",
              "",
              "// Check for 404 (patient not found)",
              "if (pm.response.code === 404) {",
              "    console.warn('Patient not found — verify athena_patient_id and athena_practice_id');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{athena_access_token}}",
            "description": "Set by Step 1 test script"
          },
          {
            "key": "Accept",
            "value": "application/xml, text/xml"
          }
        ],
        "url": {
          "raw": "{{athena_base_url}}/v1/{{athena_practice_id}}/patients/{{athena_patient_id}}/ccda",
          "host": ["{{athena_base_url}}"],
          "path": ["v1", "{{athena_practice_id}}", "patients", "{{athena_patient_id}}", "ccda"],
          "description": "TODO: verify endpoint path against athena developer docs. Alternative path: /v1/{practiceid}/ccda/{patientid}/ccda"
        },
        "description": "Retrieves the Continuity of Care Document (CCD/CCDA) for the specified patient. Returns HL7 C-CDA R2.1 XML containing encounters, medications, problems, allergies, results."
      }
    }
  ],
  "variable": [
    {
      "key": "athena_base_url",
      "value": "https://api.preview.platform.athenahealth.com"
    }
  ]
}
