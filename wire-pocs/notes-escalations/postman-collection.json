{
  "info": {
    "name": "athena Notes / Escalations — POST and GET Patient Notes",
    "description": "Pillar: Notes / Escalations (Phase 5)\nEndpoints:\n  POST /v1/{practiceid}/patients/{patientid}/notes — Post a patient note\n  GET  /v1/{practiceid}/patients/{patientid}/notes — Get existing notes\n\nFrom recon: AthenaApi.java has no /notes endpoint — this is greenfield.\nReuses store pattern from Phase 1b (same auth, same retry, new endpoint).\n\nTODO: Verify all endpoint paths and field names against athena developer docs.\n\nRequired Postman environment variables:\n  athena_client_id\n  athena_client_secret\n  athena_practice_id\n  athena_patient_id\n  athena_base_url",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Step 1 — Acquire OAuth2 Token",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const clientId = pm.environment.get('athena_client_id');",
              "const clientSecret = pm.environment.get('athena_client_secret');",
              "if (!clientId || !clientSecret) {",
              "    throw new Error('athena_client_id and athena_client_secret must be set');",
              "}",
              "const credentials = btoa(clientId + ':' + clientSecret);",
              "pm.environment.set('athena_basic_auth', 'Basic ' + credentials);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Token acquired', function () {",
              "    pm.response.to.have.status(200);",
              "    const json = pm.response.json();",
              "    pm.expect(json.access_token).to.be.a('string').and.not.empty;",
              "    pm.environment.set('athena_access_token', json.access_token);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "{{athena_basic_auth}}"},
          {"key": "Content-Type", "value": "application/x-www-form-urlencoded"}
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [{"key": "grant_type", "value": "client_credentials"}]
        },
        "url": {
          "raw": "{{athena_base_url}}/oauth2/v1/token",
          "host": ["{{athena_base_url}}"],
          "path": ["oauth2", "v1", "token"]
        }
      }
    },
    {
      "name": "Step 2 — GET Existing Patient Notes",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const token = pm.environment.get('athena_access_token');",
              "if (!token) { throw new Error('Run Step 1 first'); }",
              "const patientId = pm.environment.get('athena_patient_id');",
              "if (!patientId) { throw new Error('athena_patient_id must be set'); }"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Notes returned (200)', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "    try {",
              "        const data = pm.response.json();",
              "        const notes = Array.isArray(data) ? data : (data.notes || data.patientnotes || []);",
              "        console.log('Existing notes count: ' + notes.length);",
              "        if (notes.length > 0) {",
              "            console.log('First note: ' + JSON.stringify(notes[0]).slice(0, 200));",
              "        }",
              "    } catch (e) {",
              "        console.log('Body: ' + pm.response.text().slice(0, 500));",
              "    }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{athena_access_token}}"},
          {"key": "Accept", "value": "application/json"}
        ],
        "url": {
          "raw": "{{athena_base_url}}/v1/{{athena_practice_id}}/patients/{{athena_patient_id}}/notes",
          "host": ["{{athena_base_url}}"],
          "path": ["v1", "{{athena_practice_id}}", "patients", "{{athena_patient_id}}", "notes"],
          "description": "TODO: verify endpoint path and response shape against athena developer docs. departmentid query param may be required."
        }
      }
    },
    {
      "name": "Step 3 — POST Escalation Note",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const token = pm.environment.get('athena_access_token');",
              "if (!token) { throw new Error('Run Step 1 first'); }",
              "",
              "// Generate idempotency key based on escalation ID",
              "const escalationId = pm.environment.get('athena_escalation_id') || 'test-escalation-' + Date.now();",
              "const patientId = pm.environment.get('athena_patient_id') || '';",
              "const practiceId = pm.environment.get('athena_practice_id') || '';",
              "pm.environment.set('athena_escalation_id', escalationId);",
              "",
              "// Simple hash for idempotency key",
              "let hash = 0;",
              "const compound = 'note:' + patientId + ':' + practiceId + ':' + escalationId + ':escalation';",
              "for (let i = 0; i < compound.length; i++) {",
              "    hash = ((hash << 5) - hash) + compound.charCodeAt(i);",
              "    hash |= 0;",
              "}",
              "pm.environment.set('athena_idempotency_key', 'note-' + Math.abs(hash).toString(16));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Note posted (200 or 201)', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "if (pm.response.code >= 400) {",
              "    console.error('Note POST failed: ' + pm.response.status);",
              "    console.error('Body: ' + pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "Bearer {{athena_access_token}}"},
          {"key": "Content-Type", "value": "application/x-www-form-urlencoded"},
          {
            "key": "X-Idempotency-Key",
            "value": "{{athena_idempotency_key}}",
            "description": "Idempotency on escalation ID — same escalation = same note, not a duplicate"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "notetext",
              "value": "Brook escalation note: Blood pressure elevated (180/110). Patient notified care team. Provider review recommended.",
              "description": "Note text body. TODO: verify field name (notetext vs text vs note)"
            },
            {
              "key": "notetype",
              "value": "ESCALATION",
              "description": "Note type. TODO: verify athena accepted values for note type"
            }
          ]
        },
        "url": {
          "raw": "{{athena_base_url}}/v1/{{athena_practice_id}}/patients/{{athena_patient_id}}/notes",
          "host": ["{{athena_base_url}}"],
          "path": ["v1", "{{athena_practice_id}}", "patients", "{{athena_patient_id}}", "notes"],
          "description": "TODO: verify endpoint path and all field names against athena developer docs."
        }
      }
    }
  ],
  "variable": [
    {"key": "athena_base_url", "value": "https://api.preview.platform.athenahealth.com"}
  ]
}
