{
  "info": {
    "name": "athena Billing — Eligibility Check + Real-Time Charge Posting",
    "description": "Pillar: Billing (Phase 5)\nScope: Eligibility verification + CPT charge posting (not full claims submission)\n\nEndpoints:\n  GET  /v1/{practiceid}/patients/{patientid}/insurances — Check patient eligibility\n  POST /v1/{practiceid}/patients/{patientid}/procedures — Post CPT procedure charge\n\nTODO: Verify all endpoint paths against athena developer docs.\n      athena may route charges through /encounters or a different billing path.\n\nCPT codes by program (build plan Phase 5):\n  RPM:  99457 (primary), 99458 (additional)\n  CCM:  99490 (primary), 99439 (additional)\n  APCM: 99490 + addendums\n\nRequired Postman environment variables:\n  athena_client_id\n  athena_client_secret\n  athena_practice_id\n  athena_patient_id\n  athena_department_id\n  athena_provider_id\n  athena_base_url",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Step 1 — Acquire OAuth2 Token",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const clientId = pm.environment.get('athena_client_id');",
              "const clientSecret = pm.environment.get('athena_client_secret');",
              "if (!clientId || !clientSecret) {",
              "    throw new Error('athena_client_id and athena_client_secret must be set');",
              "}",
              "const credentials = btoa(clientId + ':' + clientSecret);",
              "pm.environment.set('athena_basic_auth', 'Basic ' + credentials);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Token acquired', function () {",
              "    pm.response.to.have.status(200);",
              "    const json = pm.response.json();",
              "    pm.expect(json.access_token).to.be.a('string').and.not.empty;",
              "    pm.environment.set('athena_access_token', json.access_token);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "{{athena_basic_auth}}"},
          {"key": "Content-Type", "value": "application/x-www-form-urlencoded"}
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [{"key": "grant_type", "value": "client_credentials"}]
        },
        "url": {
          "raw": "{{athena_base_url}}/oauth2/v1/token",
          "host": ["{{athena_base_url}}"],
          "path": ["oauth2", "v1", "token"]
        }
      }
    },
    {
      "name": "Step 2 — GET Patient Eligibility / Insurance",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const token = pm.environment.get('athena_access_token');",
              "if (!token) { throw new Error('Run Step 1 first'); }",
              "const patientId = pm.environment.get('athena_patient_id');",
              "if (!patientId) { throw new Error('athena_patient_id must be set'); }"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Eligibility data returned (200)', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "    try {",
              "        const data = pm.response.json();",
              "        const insurances = Array.isArray(data) ? data : (data.insurances || []);",
              "        console.log('Insurance records: ' + insurances.length);",
              "        if (insurances.length > 0) {",
              "            const ins = insurances[0];",
              "            console.log('Primary insurer: ' + (ins.insuranceid || ins.insurancepolicyid || ins.insurancename || JSON.stringify(ins).slice(0, 100)));",
              "        }",
              "    } catch (e) {",
              "        console.log('Body: ' + pm.response.text().slice(0, 500));",
              "    }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{athena_access_token}}"},
          {"key": "Accept", "value": "application/json"}
        ],
        "url": {
          "raw": "{{athena_base_url}}/v1/{{athena_practice_id}}/patients/{{athena_patient_id}}/insurances",
          "host": ["{{athena_base_url}}"],
          "path": ["v1", "{{athena_practice_id}}", "patients", "{{athena_patient_id}}", "insurances"],
          "description": "TODO: verify endpoint path. athena may have a dedicated eligibility check endpoint separate from /insurances."
        }
      }
    },
    {
      "name": "Step 3 — POST Procedure Charge (RPM 99457)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const token = pm.environment.get('athena_access_token');",
              "if (!token) { throw new Error('Run Step 1 first'); }",
              "",
              "// Generate idempotency key: compound of patient + practice + CPT + date + event",
              "const patientId = pm.environment.get('athena_patient_id') || '';",
              "const practiceId = pm.environment.get('athena_practice_id') || '';",
              "const cptCode = pm.environment.get('athena_cpt_code') || '99457';",
              "const chargeEventId = pm.environment.get('athena_charge_event_id') || 'ChargePosted-' + patientId + '-' + new Date().toISOString().slice(0,10);",
              "const serviceDate = pm.environment.get('athena_service_date') || new Date().toISOString().slice(0,10);",
              "",
              "pm.environment.set('athena_charge_event_id', chargeEventId);",
              "pm.environment.set('athena_service_date', serviceDate);",
              "",
              "// Simple hash for idempotency",
              "let hash = 0;",
              "const compound = 'charge:' + patientId + ':' + practiceId + ':' + cptCode + ':' + serviceDate + ':' + chargeEventId;",
              "for (let i = 0; i < compound.length; i++) {",
              "    hash = ((hash << 5) - hash) + compound.charCodeAt(i);",
              "    hash |= 0;",
              "}",
              "pm.environment.set('athena_idempotency_key', 'charge-' + Math.abs(hash).toString(16));",
              "pm.environment.set('athena_cpt_code', cptCode);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// 409 = already posted (idempotent) — not an error",
              "if (pm.response.code === 409) {",
              "    console.log('HTTP 409: Charge already posted — idempotent. Not an error.');",
              "}",
              "",
              "pm.test('Charge posted (200, 201, or idempotent 409)', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 409]);",
              "});",
              "",
              "if (pm.response.code >= 400 && pm.response.code !== 409) {",
              "    console.error('Charge POST failed: ' + pm.response.status);",
              "    console.error('Body: ' + pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "Bearer {{athena_access_token}}"},
          {"key": "Content-Type", "value": "application/x-www-form-urlencoded"},
          {
            "key": "X-Idempotency-Key",
            "value": "{{athena_idempotency_key}}",
            "description": "Prevents duplicate charge postings. Key = hash(patient+practice+CPT+date+event)"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "procedurecode",
              "value": "{{athena_cpt_code}}",
              "description": "CPT code. RPM: 99457/99458. CCM: 99490/99439. APCM: 99490 + addendums."
            },
            {
              "key": "servicedate",
              "value": "{{athena_service_date}}",
              "description": "Date of service. Format may be MM/DD/YYYY — TODO: verify with athena docs"
            },
            {
              "key": "departmentid",
              "value": "{{athena_department_id}}"
            },
            {
              "key": "providerid",
              "value": "{{athena_provider_id}}"
            }
          ]
        },
        "url": {
          "raw": "{{athena_base_url}}/v1/{{athena_practice_id}}/patients/{{athena_patient_id}}/procedures",
          "host": ["{{athena_base_url}}"],
          "path": ["v1", "{{athena_practice_id}}", "patients", "{{athena_patient_id}}", "procedures"],
          "description": "TODO: verify endpoint path. athena may route charges through /encounters/{id}/procedures or a different billing path."
        }
      }
    }
  ],
  "variable": [
    {"key": "athena_base_url", "value": "https://api.preview.platform.athenahealth.com"},
    {"key": "athena_cpt_code", "value": "99457", "description": "Default: RPM primary code"},
    {
      "key": "athena_service_date",
      "value": "",
      "description": "Set to today's date in YYYY-MM-DD format"
    }
  ]
}
